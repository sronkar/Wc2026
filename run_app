#!/bin/bash
set -e

BRANCH="claude/fifa-prediction-app-WsAHW"

echo "==> Stashing local changes (if any)..."
git stash

echo "==> Pulling latest code from $BRANCH..."
git pull origin "$BRANCH"

echo "==> Restoring local changes (if any)..."
git stash pop 2>/dev/null || true

echo "==> Installing dependencies..."
npm install

echo "==> Syncing database schema..."
npx prisma db push

echo "==> Seeding matches if database is empty..."
MATCH_COUNT=$(node -e "
const { PrismaClient } = require('@prisma/client');
const p = new PrismaClient();
p.match.count().then(c => { console.log(c); p.\$disconnect(); }).catch(() => { console.log(0); p.\$disconnect(); });
")
if [ "$MATCH_COUNT" -eq 0 ]; then
  echo "    No matches found — running seed..."
  npm run db:seed
else
  echo "    $MATCH_COUNT matches already in DB, skipping seed."
fi

echo "==> Starting dev server..."
npm run dev
