# ── Database ─────────────────────────────────────────────────────────────────
# Local SQLite (development only):
#   DATABASE_URL="file:./dev.db"
# Railway PostgreSQL (production) — copy from Railway dashboard → Variables:
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Set NEXTAUTH_URL to your Railway public domain, e.g.:
#   https://yourapp.up.railway.app
NEXTAUTH_URL="https://yourapp.up.railway.app"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/
# Add your Railway URL to Authorized redirect URIs:
#   https://yourapp.up.railway.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── Email (SMTP) for magic-link sign-in ───────────────────────────────────────
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="WC2026 Predictions <your-email@gmail.com>"

# ── Admin ─────────────────────────────────────────────────────────────────────
# This email gets the ADMIN role automatically on first login
ADMIN_EMAIL="admin@example.com"

# ── Football data API (optional) ─────────────────────────────────────────────
# Free key at https://www.football-data.org/client/register
# If not set, falls back to ESPN's unofficial API (no key needed)
FOOTBALL_DATA_API_KEY=""

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"

# ── Demo / test environment ───────────────────────────────────────────────────
# Set to "true" only in a local dev/test environment — never in production
DEMO_MODE="false"
