datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  role                    String                   @default("USER")
  isDemo                  Boolean                  @default(false)
  predictions             Prediction[]
  customPredictionAnswers CustomPredictionAnswer[]
  groupMemberships        GroupMembership[]
  accounts                Account[]
  sessions                Session[]
  pushSubscriptions       PushSubscription[]
  matchReminders          MatchReminder[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id             String          @id @default(cuid())
  matchNumber    Int             @unique
  homeTeam       String
  awayTeam       String
  group          String?
  round          String
  venue          String
  city           String
  kickoff        DateTime
  homeScore      Int?
  awayScore      Int?
  status         String          @default("SCHEDULED")
  isDemo         Boolean         @default(false)
  predictions    Prediction[]
  matchReminders MatchReminder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  groupId   String
  homeScore Int
  awayScore Int
  points    Int?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId, groupId])
}

model PointSettings {
  id                   String   @id @default(cuid())
  exactMatchPoints     Int      @default(5)
  directionMatchPoints Int      @default(1)
  updatedAt            DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model MatchReminder {
  id      String   @id @default(cuid())
  userId  String
  matchId String
  sentAt  DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match   Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model DemoSettings {
  id          String   @id @default("demo")
  virtualTime DateTime @default(now())
}

model Group {
  id                   String              @id @default(cuid())
  name                 String
  description          String?
  avatar               String?
  createdBy            String
  exactMatchPoints     Int                 @default(5)
  directionMatchPoints Int                 @default(1)
  memberships          GroupMembership[]
  predictions          Prediction[]
  customPredictions    CustomPrediction[]
  invites              GroupInvite[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model GroupMembership {
  id         String   @id @default(cuid())
  groupId    String
  userId     String
  status     String   @default("PENDING")    // PENDING | APPROVED | REJECTED
  memberRole String   @default("MEMBER")     // MEMBER | VISITOR_ADMIN
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, groupId])
}

model GroupInvite {
  id         String   @id @default(cuid())
  groupId    String
  email      String
  memberRole String   @default("MEMBER")     // MEMBER | VISITOR_ADMIN
  token      String   @unique
  status     String   @default("PENDING")    // PENDING | ACCEPTED
  createdBy  String
  expiresAt  DateTime
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model CustomPrediction {
  id            String                   @id @default(cuid())
  groupId       String
  question      String
  options       String                   // JSON-encoded string[]
  points        Int                      @default(3)
  lockTime      DateTime
  correctOption String?
  status        String                   @default("OPEN")  // OPEN | RESOLVED
  group         Group                    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  answers       CustomPredictionAnswer[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
}

model CustomPredictionAnswer {
  id                 String           @id @default(cuid())
  userId             String
  customPredictionId String
  option             String
  points             Int?
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  customPrediction   CustomPrediction @relation(fields: [customPredictionId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([userId, customPredictionId])
}
