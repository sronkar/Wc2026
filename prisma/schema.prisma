datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                   @id @default(cuid())
  name                    String?
  email                   String?                  @unique
  emailVerified           DateTime?
  image                   String?
  role                    String                   @default("USER")
  password                String?
  isDemo                  Boolean                  @default(false)
  predictions              Prediction[]
  customPredictionAnswers  CustomPredictionAnswer[]
  advancementPredictions   AdvancementPrediction[]
  groupMemberships         GroupMembership[]
  accounts                 Account[]
  sessions                 Session[]
  pushSubscriptions        PushSubscription[]
  matchReminders           MatchReminder[]
  notifications            Notification[]
  emailNotifications       Boolean                  @default(true)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Match {
  id             String          @id @default(cuid())
  matchNumber    Int             @unique
  homeTeam       String
  awayTeam       String
  group          String?
  round          String
  venue          String
  city           String
  kickoff        DateTime
  homeScore      Int?
  awayScore      Int?
  status         String          @default("SCHEDULED")
  isDemo         Boolean         @default(false)
  predictions    Prediction[]
  matchReminders MatchReminder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Prediction {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  groupId   String
  homeScore Int
  awayScore Int
  points    Int?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId, groupId])
}

model PointSettings {
  id                   String   @id @default(cuid())
  exactMatchPoints     Int      @default(5)
  directionMatchPoints Int      @default(1)
  updatedAt            DateTime @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model MatchReminder {
  id      String   @id @default(cuid())
  userId  String
  matchId String
  sentAt  DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match   Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "lock_1h" | "lock_30m" | "result" | "score_corrected" | "join_approved" | "post_game_email"
  title     String
  body      String
  matchId   String?
  groupIds  String?  // JSON array of relevant groupIds (for deep-linking; null = global)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model DemoSettings {
  id                      String   @id @default("demo")
  virtualTime             DateTime @default(now())
  simulationActive        Boolean  @default(false)
  advancementPicksLocked  Boolean  @default(false)  // sticky once true; cleared on sim reset
}

// One row per match scored during the current simulation. Replaces the old
// JSON-string column on DemoSettings which had a read-modify-write race under
// concurrent setScore calls. @@unique on matchId makes upsert-by-matchId
// trivially safe.
model SimulationScoredMatch {
  id        String   @id @default(cuid())
  matchId   String   @unique
  scoredAt  DateTime @default(now())
}

// Exclusive run-lock for cron jobs. One row per job name. withJobLock()
// creates it on acquire, deletes it on release. Stale rows older than
// the job's timeout are evicted automatically on the next acquire attempt.
model JobLock {
  jobName   String   @id
  startedAt DateTime @default(now())
  pid       Int
}

// Production health counters. Single row keyed by "default".
// Not to be confused with DemoSettings which is sim-mode state.
model SystemHealth {
  id                            String    @id @default("default")
  scorePollConsecutiveFailures  Int       @default(0)
  scorePollLastSuccessAt        DateTime?
  scorePollLastFailureAt        DateTime?
  scorePollLastErrorMessage     String?
  scorePollLastAlertAt          DateTime?
  updatedAt                     DateTime  @updatedAt
}

model Group {
  id                   String              @id @default(cuid())
  name                 String
  description          String?
  avatar               String?
  createdBy            String
  exactMatchPoints     Int                 @default(5)
  directionMatchPoints Int                 @default(1)
  stagePoints          String              @default("{}")
  joinToken            String?             @unique
  isPublic             Boolean             @default(true)
  requirePassword      Boolean             @default(false)
  memberships              GroupMembership[]
  predictions              Prediction[]
  customPredictions        CustomPrediction[]
  advancementPredictions   AdvancementPrediction[]
  invites                  GroupInvite[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model GroupMembership {
  id         String   @id @default(cuid())
  groupId    String
  userId     String
  status     String   @default("PENDING")    // PENDING | APPROVED | REJECTED
  memberRole String   @default("MEMBER")     // MEMBER | VISITOR_ADMIN
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, groupId])
}

model GroupInvite {
  id         String   @id @default(cuid())
  groupId    String
  email      String
  memberRole String   @default("MEMBER")     // MEMBER | VISITOR_ADMIN
  token      String   @unique
  status     String   @default("PENDING")    // PENDING | ACCEPTED
  createdBy  String
  expiresAt  DateTime
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model CustomPrediction {
  id            String                   @id @default(cuid())
  groupId       String?
  isGlobal      Boolean                  @default(false)
  question      String
  description   String?
  optionType    String                   @default("FIXED")  // FIXED | TEAM | PLAYER
  options       String                   // JSON-encoded string[]
  points        Int                      @default(3)
  lockTime      DateTime
  correctOption String?
  status        String                   @default("OPEN")  // OPEN | RESOLVED
  group         Group?                   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  answers       CustomPredictionAnswer[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
}

model Player {
  id       String  @id @default(cuid())
  name     String
  country  String
  position String?
  number   Int?

  @@index([country])
}

// Per-user prediction of how each team will finish the group stage
model AdvancementPrediction {
  id      String  @id @default(cuid())
  userId  String
  groupId String  // prediction group id
  team    String
  pick    String  // "WINNER" | "RUNNER_UP" | "THIRD" | "ELIMINATED"
  points  Int?
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, groupId, team])
}

// Admin-set actual group stage outcome per team
model TeamAdvancement {
  id         String   @id @default(cuid())
  team       String   @unique
  result     String   // "WINNER" | "RUNNER_UP" | "THIRD" | "ELIMINATED"
  resolvedAt DateTime @default(now())
}

model CustomPredictionAnswer {
  id                 String           @id @default(cuid())
  userId             String
  customPredictionId String
  groupId            String?          // always set; null only for legacy rows
  option             String
  points             Int?
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  customPrediction   CustomPrediction @relation(fields: [customPredictionId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([userId, customPredictionId, groupId])
}
